# Variáveis de ambiente — Dashboard de Faturamento VTEX
# Copie este arquivo para .env e preencha com os valores reais

# ---- VTEX ----
VTEX_ACCOUNT_NAME=sjdigital
VTEX_ENVIRONMENT=vtexcommercestable
VTEX_APP_KEY=vtexappkey-sjdigital-NBIBYX
VTEX_APP_TOKEN=ZWWMCOPAPYMWRDDFJXJASHHUYAHMNWFDLQKYEFYTGNOHDWBDBJGDWDRAQKGALTKTJZUTNMSEOSARVFCIQDNTEVGACYJBFYYKDFRYJTFSQJTOANANWPYYWISDULGXVMON

# ---- NeonDB (PostgreSQL) ----
# Copie a connection string do painel do NeonDB
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# ---- API ----
# Token secreto para proteger o endpoint de sincronização
SYNC_SECRET_TOKEN=gere-um-token-secreto-aqui

# ---- Configurações ----
# Quantos pedidos buscar por página na VTEX (máx. 100)
VTEX_PAGE_SIZE=100
# Intervalo entre requisições à VTEX (segundos)
VTEX_RATE_LIMIT_SLEEP=0.4
# Data de início da carga histórica (YYYY-MM-DD)
# Deixe vazio para usar a data mais antiga disponível
HISTORICAL_START_DATE=2023-01-01
